		; 
		; // C-preprocessor two-level expansion to build constant
		; #define _SAM5XXX_PORTNAME(port,val)    SAM5XXX_USB ## port ## _ ## val
		; #define SAM5XXX_PORTNAME(port,val)    _SAM5XXX_PORTNAME(port, val)
